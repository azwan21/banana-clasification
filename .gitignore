# ==========================================================
# AIoT Smart Banana Ripeness Sorting System - Git Ignore
# ==========================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyd

# C extensions
*.so

# Python Environments
.env
.venv/
venv/
ENV/
env/
scripts/

# Jupyter Notebook
.ipynb_checkpoints
profile_default/
ipython_config.py

# IDE / Editor Settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Project specific security exclusions
firebase_credentials.json

# Local temp logs or test artifacts
brain/
scratch/
logs/
*.log

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Operating System Files
.DS_Store
Thumbs.db
Desktop.ini

# Compressed Files (if not tracked by LFS)
*.zip
*.tar.gz
*.rar

# (Opsional) Dataset / Large Data jika tidak ingin di-commit
# dataset/
# data/
# images/
