# ==========================================================
# AIoT Smart Banana Ripeness Sorting System - Git Attributes
# ==========================================================
# 1. Line Ending Handling
# Auto-detect text files and normalize line endings to LF on commit
* text=auto
# Explicitly normalize line endings for source code files
*.py text eol=lf
*.ino text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
# 2. Binary files - Do not modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
# 3. Git Large File Storage (LFS) for Deep Learning Models
# Tracks Keras, TensorFlow, and TF-Lite binary model files using Git LFS
*.keras filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.tflite filter=lfs diff=lfs merge=lfs -text
*.pb filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
